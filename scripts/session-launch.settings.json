{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit",
      "Skill",
      "Task",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(jq:*)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(date *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)"
    ]
  }
}
