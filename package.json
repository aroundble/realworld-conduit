{
  "name": "realworld-conduit",
  "version": "0.0.0",
  "private": true,
  "description": "RealWorld Conduit — Next.js 16 + Hono + Prisma + PostgreSQL walking skeleton",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "lint": "pnpm -r --parallel run lint",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r --if-present --parallel run test",
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "compose:up": "docker compose -f infra/docker-compose.yml up -d --build",
    "compose:down": "docker compose -f infra/docker-compose.yml down -v",
    "smoke": "bash scripts/smoke.sh",
    "test:conformance:smoke": "bash scripts/run-newman-smoke.sh",
    "test:e2e:smoke": "playwright test --config tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "newman": "6.2.2",
    "typescript": "5.9.3"
  }
}
