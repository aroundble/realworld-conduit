{
  "info": {
    "name": "Conduit healthz smoke",
    "description": "Minimal gate-6 enabler — one request, no RealWorld feature endpoints. Full spec conformance lives in #36.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET /healthz returns {ok:true}",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{apiUrl}}/healthz",
          "host": ["{{apiUrl}}"],
          "path": ["healthz"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('body is {ok: true}', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('ok', true);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
