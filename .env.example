# Local development environment overrides.
# Copy to .env (gitignored) and fill in. Every variable must also
# have a value path in infra/config/<env>.yaml for non-local
# environments — local is the only place .env is consulted.

# ─── Auth ────────────────────────────────────────────────────────
# dev | sdk | managed — see docs/bp/auth-roles-local-vs-prod.md
AUTH_MODE=dev
# Comma-separated usernames the role switcher recognises.
# IGNORED outside local. Do NOT add to dev/prod configs.
DEV_USERS=admin,developer,user

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/app_dev

# ─── Cache ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Secrets (build-time, never persisted in image) ──────────────
# Used by BuildKit secret mounts in docker-compose. See
# docs/bp/compose-with-buildkit-secrets.md.
# GUARDRAILS_TOKEN=...

# ─── Session (harness-aware services only) ───────────────────────
# Set when running a long-lived githarness-controlled session.
# HARNESS_SESSION_ROLE=generator
# HARNESS_REPO=<org>/<repo>
# HARNESS_LANGUAGE=en
# HARNESS_TZ=UTC
